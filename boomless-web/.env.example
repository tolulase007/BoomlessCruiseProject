# Optional: base URL of the Python backend (e.g. http://localhost:8000).
# If set, the "Use Python" toggle appears in the header and the app can request results from the backend.
# If empty or unset, only the TypeScript engine is used.
# VITE_API_URL=http://localhost:8000

# Optional: Desmos graph URL for background visualization.
# If set, a Desmos graph will be displayed as a background iframe.
# VITE_DESMOS_GRAPH_URL=https://www.desmos.com/calculator/...

# Optional: Desmos graph opacity (0.0 to 1.0).
# Defaults to 0.15 if not set.
# VITE_DESMOS_OPACITY=0.15
